{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "public",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/server.py" }
  ],
  "functions": {
    "/api/server.py": {
      "runtime": "python3.11",
      "maxDuration": 60
    }
  },
  "env": {
    "FLASK_ENV": "production"
  }
}